{
  "name": "jsonresume-theme-minimal-clean",
  "version": "1.0.0",
  "description": "Tema minimalista y limpio para JSON Resume",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "npm run html:es",
    "html": "node scripts/generate-html.js",
    "html:es": "node scripts/generate-html.js --file=resume_es.json",
    "html:en": "node scripts/generate-html.js --file=resume_en.json",
    "html:professional:es": "node scripts/build-professional-theme.mjs && node scripts/generate-professional-html.js --file=resume_es.json",
    "html:professional:en": "node scripts/build-professional-theme.mjs && node scripts/generate-professional-html.js --file=resume_en.json",
    "html:stackoverflow:es": "node scripts/generate-stackoverflow-html.js --file=resume_es.json",
    "html:stackoverflow:en": "node scripts/generate-stackoverflow-html.js --file=resume_en.json",
    "pdf": "node scripts/generate-pdf.js",
    "pdf:es": "node scripts/generate-pdf.js --file=resume_es.json",
    "pdf:en": "node scripts/generate-pdf.js --file=resume_en.json",
    "pdf:mobile": "node scripts/generate-mobile-pdf.js",
    "pdf:mobile:es": "node scripts/generate-mobile-pdf.js --file=resume_es.json",
    "pdf:mobile:en": "node scripts/generate-mobile-pdf.js --file=resume_en.json",
    "pdf:professional:es": "node scripts/build-professional-theme.mjs && node scripts/generate-professional-pdf.js --file=resume_es.json",
    "pdf:professional:en": "node scripts/build-professional-theme.mjs && node scripts/generate-professional-pdf.js --file=resume_en.json",
    "pdf:professional": "node scripts/build-professional-theme.mjs && node scripts/generate-professional-pdf.js --file=resume_es.json && node scripts/generate-professional-pdf.js --file=resume_en.json",
    "pdf:stackoverflow:es": "node scripts/generate-stackoverflow-pdf.js --file=resume_es.json",
    "pdf:stackoverflow:en": "node scripts/generate-stackoverflow-pdf.js --file=resume_en.json",
    "pdf:all": "npm run validate && npm run pdf:es && npm run pdf:en && npm run pdf:professional && npm run pdf:stackoverflow:es && npm run pdf:stackoverflow:en && npm run pdf:mobile:es && npm run pdf:mobile:en",
    "validate": "npm run validate:es && npm run validate:en",
    "validate:es": "node scripts/validate-resume.js --file=resume_es.json",
    "validate:en": "node scripts/validate-resume.js --file=resume_en.json"
  },
  "keywords": [
    "jsonresume",
    "theme",
    "minimal",
    "clean",
    "cv",
    "resume"
  ],
  "author": "Oscar David Valencia Alvarez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavidValenciaX/jsonresume-theme-minimal-clean.git"
  },
  "dependencies": {
    "@jsonresume/jsonresume-theme-professional": "^1.0.18",
    "@jsonresume/schema": "^1.2.1",
    "jsonresume-theme-stackoverflow": "^3.3.0",
    "puppeteer": "^24.11.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "resume-cli": "^3.0.8"
  }
}
